# ============ Social Support Workflow Automation — environment config ============
# Copy to .env and adjust. setup.sh generates missing values automatically.

# ---- Profile (auto-set by setup.sh) ----
# local = Mac Apple Silicon / CPU-only ; cloud = Linux + NVIDIA GPU
PROFILE=local
LLM_MODEL=qwen3.5:9b-mlx
EMBED_MODEL=bge-m3

# ---- PostgreSQL (source of truth: applications, decisions, audit, idempotency) ----
POSTGRES_USER=sswa
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=sswa
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- MongoDB (raw docs + extracted JSON + GridFS images) ----
MONGO_USER=sswa
MONGO_PASSWORD=change_me_in_prod
MONGO_DB=sswa
MONGO_HOST=mongo
MONGO_PORT=27017

# ---- Qdrant (RAG over eligibility rules + enablement programs) ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ---- Neo4j (family/employment graph) ----
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_prod
NEO4J_HOST=neo4j
NEO4J_PORT=7687

# ---- Langfuse v2 (self-hosted observability) ----
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-sswa-demo
LANGFUSE_SECRET_KEY=sk-lf-sswa-demo

# ---- Ollama (local model host) ----
OLLAMA_HOST=http://host.docker.internal:11434
# Vision model for image OCR — minicpm-v:8b (tested, accurate on Emirates ID)
VISION_MODEL=minicpm-v:8b

# ---- API auth (basic-auth for public tunnel) ----
API_USERNAME=reviewer
API_PASSWORD=change_me_in_prod
BASIC_AUTH_REALM=SSWA Demo

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
UI_PORT=8501
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Synthetic data ----
N_SYNTHETIC_APPLICANTS=200
LABEL_NOISE_RATE=0.12
RANDOM_SEED=42
