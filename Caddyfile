# Caddyfile — reverse proxy + basic auth for the public tunnel (cloud profile).
# BASIC_AUTH_HASH is generated by setup.sh from API_PASSWORD before compose up.

:80 {
	# Basic auth gates everything behind the public URL
	basicauth {
		{$API_USERNAME} {$BASIC_AUTH_HASH}
	}

	# FastAPI under /api/* (prefix stripped)
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# Streamlit UI at root (websockets proxied automatically)
	reverse_proxy ui:8501
}
