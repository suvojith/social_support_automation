# Caddyfile — reverse proxy for the public tunnel (cloud profile).
# The demo runs open; add a basicauth block here to gate access if needed.

:80 {
	# FastAPI under /api/* (prefix stripped)
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# Streamlit UI at root (websockets proxied automatically)
	reverse_proxy ui:8501
}
